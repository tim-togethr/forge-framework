{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "clear|compact|startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/session-start.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/post-skill-telemetry.sh"
          }
        ]
      }
    ]
  }
}
